{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoopWorkerResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "role",
    "status",
    "contract_hash",
    "total_score",
    "scores",
    "actions_taken",
    "verification",
    "evidence",
    "blockers",
    "experience",
    "next_run_instruction"
  ],
  "properties": {
    "role": {"const": "worker"},
    "status": {"enum": ["IMPLEMENTED", "AUTOMATION_VERIFIED", "PARTIALLY_VERIFIED", "BLOCKED"]},
    "contract_hash": {"type": "string", "minLength": 16},
    "total_score": {"type": "number", "minimum": 0, "maximum": 100},
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal_completion", "usability", "quality", "ux_readability", "stability_correctness", "delivery_completeness"],
      "properties": {
        "goal_completion": {"type": "number", "minimum": 0, "maximum": 25},
        "usability": {"type": "number", "minimum": 0, "maximum": 20},
        "quality": {"type": "number", "minimum": 0, "maximum": 20},
        "ux_readability": {"type": "number", "minimum": 0, "maximum": 15},
        "stability_correctness": {"type": "number", "minimum": 0, "maximum": 10},
        "delivery_completeness": {"type": "number", "minimum": 0, "maximum": 10}
      }
    },
    "actions_taken": {"type": "array", "items": {"type": "string"}},
    "verification": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "experience": {"type": "array", "items": {"type": "string"}},
    "next_run_instruction": {"type": "string"}
  }
}
